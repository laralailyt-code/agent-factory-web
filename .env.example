# Copy this file to .env and fill in your keys

# === Required for real LLM mode ===
# Without this, runs in MOCK mode (no API calls · canned responses · for dev/test)
# Get a key at: console.anthropic.com
ANTHROPIC_API_KEY=

# Force mock mode (skips real API calls even if key is set)
MOCK_LLM=false


# === Deployment targets (only needed in REAL mode) ===
# For monitoring agents (war room, KPI brief) deployed to Render
RENDER_API_KEY=

# For websites deployed to Vercel
VERCEL_TOKEN=


# === Telegram bot entry (D3 / W2) ===
TG_BOT_TOKEN=
TG_CHAT_ID=


# === D3.1 · 真打包 .exe 開關 (excel_diff demo) ===
# 設 true 之後跑 excel_diff 會真的呼叫 PyInstaller 產 .exe (30-90 秒)
# 需要先 pip install pyinstaller pandas openpyxl
RUN_PYINSTALLER=false
